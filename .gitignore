# Build outputs — regenerated by scripts/build.sh.
build/*
!build/.gitkeep

# Tectonic / LaTeX intermediate files. Kept out of source.
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz
*.fls
*.fdb_latexmk

# OS / editor noise.
.DS_Store
*.swp
.idea/
.vscode/

# Tectonic cache (in case TECTONIC_CACHE_DIR isn't set globally).
.tectonic-cache/
